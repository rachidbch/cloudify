function inventory {

  # Without filter, return all hosts
  # Remove host duplicates while retaining host order (see awk incantation below)
  {
      [[ $# == 0 ]] && ls -d $CLOUDIFY_DIR/inventory/*/ | xargs -I {} basename {}
    
      for filter in "$@"; do
          if [[ "$filter" != \@* ]]; then
             # If filter is an host, check if it exist
             ls -d $CLOUDIFY_DIR/inventory/"$filter"/  | xargs -I {} basename {}
          else
             # If filter is a tag, filter all hosts with that tag 
             ls -d $CLOUDIFY_DIR/inventory/*/"$filter" | xargs -I {} dirname {} | xargs -I {} basename {}
          fi
      done
  }  | awk '!a[$0]++' 
}

function testCode () {

  echo
  echo inventory:
  echo -e "--------"
  inventory @infra @cluster

