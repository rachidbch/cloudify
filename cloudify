# Initial configurations before applying script actions
# Ensure tmp folder exist, local bin exist and is in the path 
# Test platform on which sript is running
function preconfigure() {
  PKG_DEBUG "Running Preconfiguration"
  # Ensure all required credentials are set in proper environment variables
  $SKIPCREDENTIALS || check_credentials

  # Ensure tmp folder exists
  [[ -d "$CLOUDIFY_TMP" ]] || mkdir -p "$CLOUDIFY_TMP"

  # Ensure ~/.local/bin exists and is in the path
  [[ -d "$LOCAL_BIN" ]] || mkdir -p "$LOCAL_BIN"
  [[ ":${PATH}:" != *":${LOCAL_BIN}:"* ]] && export PATH="${PATH}:${LOCAL_BIN}"
  ## Make it persistent 
  ## DIRTY HACK! The comment '# CLOUDIFY LOCAL BIN:' is used by cloudify to avoid doublons in .bashrc
  if ! grep -Fq "# CLOUDIFY LOCAL BIN:" $HOME/.bashrc; then 
    echo -e "\n# CLOUDIFY LOCAL BIN: Cloudify may install utility scripts in ~/.local/bin" >> "$HOME"/.bashrc
    echo 'export LOCAL_BIN="$HOME"/.local/bin' >> "$HOME"/.bashrc
    echo '[[ -d "$LOCAL_BIN" ]] || mkdir -p "$LOCAL_BIN"' >> "$HOME"/.bashrc
    echo '[[ ":${PATH}:" != *":${LOCAL_BIN}:"* ]] && export PATH="${PATH}:${LOCAL_BIN}"' >> "$HOME"/.bashrc
  fi 
  
  # Are we on Android Termux or Linux station?
  if [ ! -z "$(pgrep -f com.termux)" ]; then
    export PKG_PLATFORM="termux"
    packages_file=${CLOUDIFY_DIR}/termux.packages
    pkg_init_file=$PKG_INIT_FILE_TERMUX
    PKG_DEBUG "Package init file name: $pkg_init_file"
  else
    packages_file=${CLOUDIFY_DIR}/station.packages
    pkg_init_file=$PKG_INIT_FILE_DEFAULT
    PKG_DEBUG "Package init file name: $pkg_init_file"
  fi
}


