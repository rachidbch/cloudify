# Print messages with colors
# msg sends its output to stderr (See 12 Factors CLI app principles) and support special color codes
# msg "This is a ${RED}very important${RESET} message, but not a script output value!"
function msg() {
    if [[ "${1-}" == "-n" ]]; then
        shift
        echo >&2 -n -e "$@"
    else
        echo >&2 -e "$@"
    fi
}

# Same as 'msg' but adds an empty line
function msg_ln() {
    echo >&2 && msg "$@"
}

# Die gracefully
# Usage: `die "This requirement isn't met" 1
function die() {
    local msg=$1
    local code=${2-1} # default exit status 1
    msg "${RED}$msg${RESET}"
    exit "$code"
}

# Simple function to detect the OS we're running on
# Usage:
# $ os detect:                 returns "gnux/linux ubuntu 18.04 lts"
# $ os detect --os:            returns "gnux/linux"
# $ os detect --distro:        returns "ubuntu"
# $ os detect --version:       returns "18.04"
# $ os detect --lts:           returns "lts" (or nothing if not an lts version)
# $ os detect --arch:          returns "x86_64"
# $ os detect --kernel:           returns "4.15.0-147-generic"
function cloudify_osdetect() {
    # Is this Termux on Android?
    local arch
    local kernel
    local os
    local distro
    local distroname
    local lts
    local version

    if [ ! -z "$(pgrep -f com.termux)" ]; then
        os="android"
        distro="termux"
        version="" # Not needed so far
        lts=""     # Not needed so far
        kernel=""  # Not needed so far
        arch=""    # Not needed so far
    else
        arch=$(uname -m)
        kernel=$(uname -r)

        # Get distribution name
        distroname
        if [[ -n "$(command -v lsb_release)" ]]; then
            distroname=$(lsb_release -s -d)
        elif [[ -f "/etc/os-release" ]]; then
            distroname=$(grep PRETTY_NAME /etc/os-release | sed 's/PRETTY_NAME=//g' | tr -d '="')
        elif [[ -f "/etc/debian_version" ]]; then
            distroname="Debian $(cat /etc/debian_version)"
        elif [[ -f "/etc/redhat-release" ]]; then
            distroname=$(cat /etc/redhat-release)
        else
            distroname="$(uname -s) $(uname -r)"
        fi
        distroname=$(echo $distroname | tr '[A-Z]' '[a-z]')

        # Get OS
        os
        os=$(echo "$(uname -o)" | tr '[A-Z]' '[a-z]')
        os=${os#gnu/}

        # Get Distribution Version
        distro
        distro=$(echo "$distroname" | cut -d' ' -f 1)

        # Get Distribution version
        version
        version=$(echo "$distroname" | cut -d' ' -f 2 | cut -c 1-5)

        # Is it an LTS version?
        lts
        lts=$(echo "$distroname" | cut -d' ' -f 3)
    fi

    case "$1" in
    --os)
        echo $os
        ;;
    --distro)
        echo $distro
        ;;
    --version)
        echo $version
        ;;
    --lts)
        echo $lts
        ;;
    --arch)
        echo $arch
        ;;
    --kernel)
        echo $kernel
        ;;
    *)
        echo $os $distro $version $lts
        ;;
    esac
}

