#== MAIN PARSE SCRIPT PARAMETERS 
#  cloudify:                    print help
#  cloudify help:               print help  
#  cloudify ls|list [all]:      list installable packages 
#  cloudify ls|list defaults:   list default packages 
#  cloudify i <pkg>             install package
#  cloudify i defaults          install default in termux|station.packages
#  cloudify u <pkg>             uninstall package

function cloudify () {
  # Setup colors
  setup_colors

  PKG_DEBUG_LN "*** Cloudify $@"
  host='localhost'
  hosts=""
  hosts_parsing="not started"
  packages=""
  packages_parsing="not started"


  # Parse script parameters
  while :; do
    [[ -z "$1" ]] && break
    case "$1" in
    -h  | --help | help)
          usage
          break
          ;;
    -v  | --verbose | verbose) set -x ;;
    -n  | --no-color) NO_COLOR=1 ;;
    packages | pkgs | pkg)          
          if [[ -z "${2-}" || "${2-}" == "all" ]]; then
            pkg_list_all 
          elif [[ "${2-}" == "defaults" ]]; then
            pkg_list_defaults
          else
            shift && pkg_show "$@"
          fi
          break ;; 
    init)
	  #pkg_pause "installing askpassstars"
	  SKIPCREDENTIALS=true preconfigure
	  SKIPDONEMESSAGE=true pkg_install askpassstars
	  #pkg_pause "installing credentials"
	  cloudify credentials
	  ;;
    hosts)
	  lxc list cloudhorse:
	  ;;
    host)
	  lxc list cloudhorse:$2
	  ;;
    launch | run)
          local hostpwd="${CLOUDIFY_LOCALHOSTPWD}" 
          [[ -z ${hostpwd} ]] && die "Host password not set"
	  local host_image="$2"
          local host="$3"
          local restparams=${@:4} 

          if [[ "$host_image" != *:* ]]; then
              host_image="ubuntu:" 
	      host="$2" 
	      restparams=${@:3}
	  fi

          PKG_DEBUG lxc launch "$host_image" cloudhorse:"$host" -p default $restparams
          lxc launch "$host_image" cloudhorse:"$host" -p default $restparams
          # =TODO= test exit code
          hostip="" 
          while [[ ! $hostip =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; do
              hostip=$(lxc list -c4 --format csv cloudhorse:$host | cut -d' ' -f1)
          done
	  $CLOUDIFY_DEBUG && pkg_pause "line before add_in_hosts"
          add_in_hosts "$hostip $host $host.remote" 
	  $CLOUDIFY_DEBUG && pkg_pause "line after add_in_hosts"
          
          ;;
    delete | del)
          local hostpwd="${CLOUDIFY_LOCALHOSTPWD}" 
          [[ -z ${hostpwd} ]] && die "Host password not set"
          host="$2"

          if ! lxc delete cloudhorse:"$host" ${@:3} &>/dev/null; then die "Error deleting $host. Are you sure the host exist?"; fi

          # =TODO= I had to redirect sudo output to /dev/null to avoid the prompt beeing displayed. Even with "-p ''". Why that? 
          command sudo -kS -p '' sed -ri "/^[0-9]+.[0-9]+.[0-9]+.[0-9]+ $host $host.remote$/d" /etc/hosts  &>/dev/null <<< "$hostpwd"
          ;;
    shell)
	  [[ -z $2 ]] && die "Missing host"
          ssh -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" $2
	  ;;
    --on | on | o)  
          # Build hosts list
          [[ $packages_parsing == "started" ]] && die "Cloudify usage error: unexptected on block."
          [[ $hosts_parsing == "started" ]] && die "cloudify usage error: 'on' statement already encountered"

          hosts_parsing="started"
          packages="" 
          hosts=""

          while true; do
            # first, die out on invalid argument
            [[ "$2" == "--on" || "$2" == "on" || "$2" == "o" ||  "$2" == "--help" ||  "$2" == "help" || "$2" == "-h" || "$2" == "--list" || "$2" == "list" || "$2" == "l" || "$2" == "--credentials" || "$2" == "credentials" ||  "$2" == "c" || "$2" == "--test" || "$2" == "test" || "$2" == "t" ]] &&  "Argument syntax error: '$2' invalid inside an 'on' block"
            # If any of these is encountered, there's no more hosts, we can go ahead and setup the hosts
            [[ -z "$2" || "$2" == -* ||  "$2" == "install" || "$2" == "inst" || "$2" == "i" || "$2" == "uninstall" || "$2" == "u" ]] && { 
              [[ -z "$hosts" ]] && die "Cloudify usage error: No host found."
              hosts_parsing="ended" 
              break    # Hosts have been consummed, go ahead and parse next arguments
            }
            [[ -z "$hosts" ]] && hosts="$2" || hosts="$hosts $2"
            shift
          done
          [[ -z "$2" ]] && die "No packages found for hosts: $hosts"
          ;;
     --install | install |inst | i | --uninstall | uninstall | u)  
	  # pkg_pause "executing install subcommand"
          # Build packages list
          [[ $hosts_parsing == "started" ]] && die "Cloudify usage error: unexptected action '$1'"
          [[ -z "$hosts" ]] && hosts="localhost"
          packages_parsing="started"

          local action=''
          case "$1" in
            --install | install |inst | i)
              action='install' 
            ;;
            --uninstall | uninstall | u)  
              action='uninstall' 
          esac

          [[ -z "$packages" ]] &&  packages="--$action" || packages="$packages --$action"


          while true; do
            # first, die out on invalid argument
            [[ "$2" == "--help" ||  "$2" == "help" || "$2" == "-h" || "$2" == "--list" || "$2" == "list" || "$2" == "l" || "$2" == "--credentials" || "$2" == "credentials" ||  "$2" == "c" || "$2" == "--test" || "$2" == "test" || "$2" == "t" ]] &&  die "Argument syntax error: '$2' invalid inside an action block."
            
            # If any of these is encountered, there's no more packages in this package section. Go ahead and parse next package section
            [[ "$2" == "--install" || "$2" == "install" || "$2" == "i" ||  "$2" == "--uninstall" || "$2" == "uninstall" || "$2" == "u" ]] && {
                [[ "$packages" == *--install ]] && die "Cloudify usage error: Empty package section."
              
                [[ "$hosts" == "localhost" ]] && {
                    # Cloudify is executed on localhost. Either because cloudify is executed agains local machine,
                    # we're inside a remote execution. Either way, we can safely execute each package sequentially.
                    # Ensure environment variables are set and set default values otherwise 
                    preconfigure
                    # Go install or uninstall
                    if [[ "$action" == "install" ]]; then 
                        PKG_DEBUG "${YELLOW}pkg_install ${packages/--$action}${RESET}"
                        pkg_install ${packages/--$action}
                    elif [[ "$action" == "uninstall" ]]; then 
                        PKG_DEBUG "${YELLOW}pkg_uninstall ${packages/--$action}${RESET}"
                        pkg_uninstall ${packages/--$action}
                    else
                        die "Unexecpected package action: $action"
                    fi

                    # Make sure each package is processed once
                    packages=""
                 }
                  
                 break    # packages to install have been consummed, go ahead and gather packages to remove 
            } # End of detect install / uninstall test 

            # If any of these is encountered, there's no more packages, we can go ahead and install them 
            [[ -z "$2" || "$2" == "--on" || "$2" == "on" || "$2" == "o" ]] && {
              [[ "$packages" == *--install ]] && die "Cloudify usage error: Empty package section."
              packages_parsing="ended" 
              # Install/Remove packages on hosts
              for host in $hosts; do
                if [[ "$hosts" == "localhost" ]]; then

                    # Ensure environment variables are set and set default values otherwise 
                    # Cloudify is executed on localhost. Either because cloudify is executed agains local machine,
                    # we're inside a remote execution. Either way, we can safely execute each package sequentially.
                    preconfigure
                    # Go install or uninstall
                    if [[ "$action" == "install" ]]; then 
                      PKG_DEBUG "${YELLOW}pkg_install ${packages/--$action}${RESET}"
                      pkg_install ${packages/--$action}
                    elif [[ "$action" == "uninstall" ]]; then 
                      PKG_DEBUG "${YELLOW}pkg_uninstall ${packages/--$action}${RESET}"
                      pkg_uninstall ${packages/--$action}
                    else
                      die "Unexecpected package action: $action"
                    fi
                else
                  PKG_DEBUG_LN "${GREEN}cloudify_remote $host $packages${RESET}"
		  # =TODO= Should this be done in a sub-process? 
                  cloudify_remote "$host" "$packages"
                fi
              done
              break    # All packages have been consummed, go ahead and install/remove them  
            }
            packages="$packages $2"
            shift
          done
          ;;      
     --credentials | credentials | c) 
          check_credentials --force               # Ask all credentials 
          break ;;
     --test | test | t) 
          shift && testCode "$@"
          break ;;
#   -p  | --param) # Named parameter
#         param="${2-}"
#         shift
#         ;;
    -?*) die "Error: Unknown option '$1'" 1;;
    *) break ;;
    esac
    shift
  done

  # Wait until all background tasks return
  msg "${GREEN}Setup of machines in progess...${RESET}"
  wait

  return 0

# Check required params and arguments
#  [[ -z "${param-}" ]] && die "Missing required parameter: param"
#  [[ ${#args[@]} -eq 0 ]] && die "Missing script arguments"
}

#== MAIN: EXECUTE SCRIPT!
cloudify "$@"

