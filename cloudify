# Simple break command to ease debug
# Pauses until you type enter
function pkg_pause() {
  local _ 
  [[ -z $1 ]] && read -p "Cloudify is paused. Type enter to continue"  _ || read -p "Cloudify is paused at $1. Type enter to continue"  _
}


