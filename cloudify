#=WORK=
function main() {

    # Setup colors
    cloudify_setup_colors

    #PKG_DEBUG_LN "*** Cloudify $@"
    local hosts=""
    local packages=""

    local is_parsing_hosts=false
    local is_parsing_packages=false
    local is_setup_in_progress=false

    # No arguments are give, show usage
    [[ "$#" == 0 ]] && usage && exit 0

    # Parse script parameters
    while :; do
        [[ -z "$1" ]] && break
        case "$1" in
        -h)
            usage
            break
            ;;
        -v)
            set -x
            ;;
        -n)
            export CLOUDIFY_DISABLE_COLORS=true
            cloudify_setup_colors
            ;;
        environment | env) # =todo= init
            shift && cloudify_env $@
            break
            ;;
        hosts | hst) # ex inventory
            shift
            CLOUDIFY_SKIPCREDENTIALS=true cloudify_init_paths # Initialize paths (but no need to check credentials)
            if [[ -z "${1-}" || "${1-}" == "@all" ]]; then
                # If no arguments or if virtual tag '@all' is given, list all inventory hosts
                cloudify_list_hosts_by_tags
            else
                # List packages matching filters (packages names or tags)
                cloudify_list_hosts_by_tags "$@"
            fi
            break
            ;;
            # We info about servers: For LXD servers, we query LXd servers
            #lxc list $LXDSERVER:
            #lxc list "$LXDSERVER:$2"
            #;;
        packages | pkg)
            shift
            CLOUDIFY_SKIPCREDENTIALS=true cloudify_init_paths # Initialize paths (but no need to check credentials)
            if [[ "${1-}" == "show" ]]; then
                # Show packages installation code
                shift && cloudify_show_package_code "$@"
            elif [[ -z "${1-}" || "${1-}" == "@all" ]]; then
                # If no arguments or if virtual tag '@all' is given, list all packages
                packages | column
            else
                # List packages matching filters (packages names or tags)
                packages "$@"
            fi
            break
            ;;
        launch | run)
            local hostpwd="${CLOUDIFY_LOCAL_PWD}"
            [[ -z ${hostpwd} ]] && die "Host password not set"

            local host_image="$2"
            local host="$3"
            local restparams=${@:4}

            if [[ "$host_image" != *:* ]]; then
                host_image="ubuntu:"
                host="$2"
                restparams=${@:3}
            fi

            PKG_DEBUG lxc launch "$host_image" $LXDSERVER:"$host" -p default $restparams
            lxc launch "$host_image" $LXDSERVER:"$host" -p default $restparams
            # =TODO= test exit code
            hostip=""
            while [[ ! $hostip =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; do
                hostip=$(lxc list -c4 --format csv $LXDSERVER:$host | cut -d' ' -f1)
            done

            $DEBUG && PKG_PAUSE "line before add_in_hosts"
            add_in_hosts "$hostip $host $host.remote"
            $DEBUG && PKG_PAUSE "line after add_in_hosts"
            ;;
        delete | del)
            local hostpwd="${CLOUDIFY_LOCAL_PWD}"
            [[ -z ${hostpwd} ]] && die "Host password not set"
            host="$2"

            PKG_DEBUG "Executing: lxc delete $LXDSERVER:"$host" ${@:3}"
            if ! lxc delete $LXDSERVER:"$host" ${@:3} --force &>/dev/null; then die "Error deleting $host. Are you sure the host exist?"; fi

            # =TODO= I had to redirect sudo output to /dev/null to avoid the prompt beeing displayed. Even with "-p ''". Why that?
            # =TODO= Also remove IPV6 entries...
            PKG_DEBUG "Executing: sudo sed -ri \"/^[0-9]+.[0-9]+.[0-9]+.[0-9]+ $host $host.remote$/d\" /etc/hosts"
            command sudo -kS -p '' sed -ri "/^[0-9]+.[0-9]+.[0-9]+.[0-9]+ $host $host.remote$/d" /etc/hosts &>/dev/null <<<"$password"
            ;;
        shell | sh)
            # =todo= If shell commands are given, they should be executed and after what you should stay in the shell
            # =todo= The shell should forced to be bash
            [[ -z $2 ]] && die "Missing host"
            shift
            local host="$1"
            shift
            ssh -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" "$host" "$@" 2>&1 | tail -n +2
            # =HACK= We remove the first line of the output because it's invariably: "Warning: Permanently added 'hostIP' (ECDSA) to the list of known hosts"
            ;;
        execute | exec)
            # Execute shell commands on local machine or one remote hosts
            # The only upside is to have sudo command prefilled
            shift

            [[ -z $1 ]] && die "Missing host"
            local host="$1"
            shift
            if [[ $host == "localhost" ]]; then
                source <(echo "$@")
            else
                # Actual command is escaped because it can contain ';' which messes with how cloudify_remote works:
                # Indeed as the `cloudify exec` command is executed on remote host, whatever comes before ';' is executed
                # and what comes after the ';' is executed as an independant command
                cloudify_remote_sync "$host" exec localhost "\"$@\""
            fi
            break
            ;;
        credentials | crd)
            cloudify_check_credentials --force # Ask all credentials
            break
            ;;
        info)
            shift && cloudify_info "$@"
            break
            ;;
        hostnames | hsn)
            PKG_DEBUG "In cloudify, Running: " cloudify_hostnames "$@"
            shift && cloudify_hostnames "$@"
            break
            ;;
        test)
            shift && testCode "$@"
            break
            ;;
        --on)
            # Build hosts list
            [[ $is_parsing_packages == "started" ]] && die "Cloudify usage error: unexptected on block."
            [[ $is_parsing_hosts == "started" ]] && die "cloudify usage error: 'on' statement already encountered"

            is_parsing_hosts="started"
            packages=""
            hosts=""

            while true; do
                # first, die out on invalid argument
                [[ "$2" == "--on" || "$2" == "on" || "$2" == "o" || "$2" == "--help" || "$2" == "help" || "$2" == "-h" || "$2" == "--list" || "$2" == "list" || "$2" == "l" || "$2" == "--credentials" || "$2" == "credentials" || "$2" == "c" || "$2" == "--test" || "$2" == "test" || "$2" == "t" ]] && die "Argument syntax error: '$2' invalid inside an 'on' block"

                # If any of these is encountered, there's no more hosts, we can go ahead and setup the hosts
                [[ -z "$2" || "$2" == -* || "$2" == "install" || "$2" == "inst" || "$2" == "i" || "$2" == "uninstall" || "$2" == "u" ]] && {
                    [[ -z "$hosts" ]] && die "Cloudify usage error: No host found."
                    is_parsing_hosts="ended"
                    break # Hosts have been consummed, go ahead and parse next arguments
                }
                # Add current host to hosts list
                local hosts_to_add="$2"
                [[ "$2" == @* ]] && hosts_to_add=$(cloudify_list_hosts_by_tags "$2")

                if [[ -z "$hosts" ]]; then
                    hosts="$hosts_to_add"
                else
                    hosts="$hosts $hosts_to_add"
                fi
                shift
            done
            [[ -z "$2" ]] && die "No packages found for hosts: $hosts"
            ;;
        install | inst | i | uninstall | u)
            # PKG_PAUSE "executing install subcommand"
            # Build packages list
            [[ $is_parsing_hosts == "started" ]] && die "Cloudify usage error: unexptected action '$1'"
            [[ -z "$hosts" ]] && hosts="localhost"
            is_parsing_packages="started"

            local action=''
            case "$1" in
            --install | install | inst | i)
                action='install'
                ;;
            --uninstall | uninstall | u)
                action='uninstall'
                ;;
            esac

            [[ -z "$packages" ]] && packages="--$action" || packages="$packages --$action"

            while true; do
                # first, die out on invalid argument
                [[ "$2" == "--help" || "$2" == "help" || "$2" == "-h" || "$2" == "--list" || "$2" == "list" || "$2" == "l" || "$2" == "--credentials" || "$2" == "credentials" || "$2" == "c" || "$2" == "--test" || "$2" == "test" || "$2" == "t" ]] && die "Argument syntax error: '$2' invalid inside an action block."

                # If any of these is encountered, there's no more packages in this package section. Go ahead and parse next package section
                [[ "$2" == "--install" || "$2" == "install" || "$2" == "i" || "$2" == "--uninstall" || "$2" == "uninstall" || "$2" == "u" ]] && {
                    [[ "$packages" == *--install ]] && die "Cloudify usage error: Empty package section."

                    [[ "$hosts" == "localhost" ]] && {
                        # Cloudify is executed on localhost. Either because cloudify is executed agains local machine,
                        # we're inside a remote execution. Either way, we can safely execute each package sequentially.
                        # Ensure environment variables are set and set default values otherwise
                        cloudify_init_paths
                        # Go install or uninstall
                        if [[ "$action" == "install" ]]; then
                            PKG_DEBUG "${YELLOW}cloudify_install_package ${packages/--$action/}${RESET}"
                            (cloudify_install_package ${packages/--$action/}) &
                            is_setup_in_progress=true
                        elif [[ "$action" == "uninstall" ]]; then
                            PKG_DEBUG "${YELLOW}cloudify_uninstall_package ${packages/--$action/}${RESET}"
                            (cloudify_uninstall_package ${packages/--$action/}) &
                            is_setup_in_progress=true
                        else
                            die "Unexecpected package action: $action"
                        fi
                        # Make sure each package is processed once
                        packages=""
                    }

                    break # packages to install have been consummed, go ahead and gather packages to remove
                }         # End of detect install / uninstall test

                # If any of these is encountered, there's no more packages, we can go ahead and install them
                [[ -z "$2" || "$2" == "--on" || "$2" == "on" || "$2" == "o" ]] && {
                    [[ "$packages" == *--install ]] && die "Cloudify usage error: Empty package section."
                    is_parsing_packages="ended"
                    # Install/Remove packages on hosts
                    for host in $hosts; do
                        if [[ "$hosts" == "localhost" ]]; then
                            # Ensure environment variables are set and set default values otherwise
                            # Cloudify is executed on localhost. Either because cloudify is executed agains local machine,
                            # we're inside a remote execution. Either way, we can safely execute each package sequentially.
                            cloudify_init_paths
                            # Go install or uninstall
                            if [[ "$action" == "install" ]]; then
                                PKG_DEBUG "${YELLOW}cloudify_install_package ${packages/--$action/}${RESET}"
                                (cloudify_install_package ${packages/--$action/}) &
                                is_setup_in_progress=true
                            elif [[ "$action" == "uninstall" ]]; then
                                PKG_DEBUG "${YELLOW}cloudify_uninstall_package ${packages/--$action/}${RESET}"
                                (cloudify_uninstall_package ${packages/--$action/}) &
                                is_setup_in_progress=true
                            else
                                die "Unexecpected package action: $action"
                            fi
                        else
                            PKG_DEBUG_LN "${GREEN}cloudify_remote $host $packages${RESET}"
                            # =TODO= Should this be done in a sub-process?
                            cloudify_remote "$host" "$packages" && is_setup_in_progress=true
                        fi
                    done
                    break # All packages have been consummed, go ahead and install/remove them
                }
                packages="$packages $2"
                shift
            done
            ;;
        -?*) die "Error: Unknown option '$1'" 1 ;;
        *) break ;;
        esac
        shift
    done

    # Print Setup in progress only if we launched background setup
    $is_setup_in_progress && {
        # Wait until all background tasks return
        msg "${GREEN}Setup of machines in progress...${RESET}"
        wait
        msg "${GREEN}Setup Done.${RESET}"
    }
    return 0

    # Check required params and arguments
    #  [[ -z "${param-}" ]] && die "Missing required parameter: param"
    #  [[ ${#args[@]} -eq 0 ]] && die "Missing script arguments"
}

