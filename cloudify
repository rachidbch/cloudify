# Cloudify environement sub-command
function cloudify_environment() {
    while :; do
        [[ -z "$1" ]] && break
        case "$1" in
        init)
            # Initialize paths (but no need to check credentials)
            CLOUDIFY_SKIPCREDENTIALS=true cloudify_init_paths
            # Install askpass only if it isn't already present
            if ! source $CLOUDIFY_DIR/pkg/askpassstars/present.sh; then
                SKIPDONEMESSAGE=true cloudify_install_package askpassstars
                cloudify credentials
            fi
            break
            ;;
        -?*) die "Error: Unknown option '$1' for command 'cloudify env'" 1 ;;
        *) break ;;
        esac
    done
}

