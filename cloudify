#== SCRIPT USAGE
function usage() {
    cat <<'EOF'
    cloudify [action] [package]
    examples:
        cloudify help                                   print this usage help 
        cloudify init                                   Initialize cloudify before use (required once per session)
        cloudify credentials|c                          Sets credentials (local host, remote hosts, github, gitlab)
        cloudify packages|pkgs                          list installable packages 
        cloudify packages|pkgs default                  list default packages 
        cloudify add | a <pkg>                          install package on local machine
        cloudify add | a  default                       install default packages on local machine
        cloudify remove| rem | r <pkg>                  uninstall package
        cloudify hosts                                  list remote hosts
        cloudify host <host>                            print <host> remote host status
        cloudify <host> shell                           open a shell session on <host> remote host
        cloudify ... --on <host>                                 <host> remote host to run action on
        cloudify test|t                                 helper to test code 
        cloudify hostnames <host> [IP]                  Add <host>'IP in /etc/hosts
EOF
}

