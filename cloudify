#!/usr/bin/env bash
# Cloudify all-in-one machine, containers and software packages management tool
#
# Thin CLI router — all logic is in lib/*.sh modules

# STRICT MODE ERROR HANDLING
set -Eeuo pipefail

#== SCRIPT USAGE
function usage() {
    cat <<'EOF'
    cloudify [action] [package]
    examples:
        cloudify help                                   print this usage help
        cloudify init                                   Full setup: PATH, tools, credentials (once per machine)
        cloudify credentials|c                          Set all credentials interactively
        cloudify credentials <section>                  Set specific credentials (remote, github, gitlab)
        cloudify credentials --check                    Check credential status
        cloudify packages|pkgs                          list installable packages
        cloudify packages|pkgs default                  list default packages
        cloudify add | a <pkg>                          install package on local machine
        cloudify add | a  default                       install default packages on local machine
        cloudify remove| rem | r <pkg>                  uninstall package
        cloudify launch|run [remote:]<name> [image]     Launch container (default image: ubuntu/24.04/cloud)
        cloudify delete|del [remote:]<name>             Delete container
        cloudify hosts                                  list remote hosts
        cloudify host <host>                            print <host> remote host status
        cloudify <host> shell                           open a shell session on <host> remote host
        cloudify ... --on <host>                                 <host> remote host to run action on
        cloudify test|t                                 helper to test code
        cloudify hostnames <host> [IP]                  Add <host>'IP in /etc/hosts
        cloudify exec <host> <cmd>                      Run command on remote host
EOF
}

#== SCRIPT PATH
CLOUDIFY_SCRIPT_DIR=$(cd "$(dirname "$( [ -L "${BASH_SOURCE[0]}" ] && readlink -f "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}" )")" &>/dev/null && pwd -P)

#== CONSTANTS
export CLOUDIFY_LOCAL_BIN="$HOME"/.local/bin
: "${EDITOR:=vim}" && export EDITOR
export CLOUDIFY_RECIPE_FILENAME="init.sh"
export CLOUDIFY_BOOTSTRAP_URL="https://gist.githubusercontent.com/rachidbch/2e10095b0042e784c557a15e2c804807/raw/3741c58d083f1463f6580e792f75ec227744a304/cloudify.sh"
export CLOUDIFY_TMP=/tmp/cloudify

#== ENVIRONMENT
: "${CLOUDIFY_IS_LOCAL:=true}" && export CLOUDIFY_IS_LOCAL
: "${CLOUDIFY_DIR:=$HOME/cloudify}" && export CLOUDIFY_DIR
export CLOUDIFY_INIT_COOKIE="$CLOUDIFY_DIR/.initialized"
: "${CLOUDIFY_DISABLE_COLORS:=false}" && export CLOUDIFY_DISABLE_COLORS
: "${CLOUDIFY_UPDATE_DELAY:=30}" && export CLOUDIFY_UPDATE_DELAY
: "${CLOUDIFY_FORCE_UPDATE:=false}" && export CLOUDIFY_FORCE_UPDATE
export CLOUDIFY_DEFAULT_OS="ubuntu"
: "${CLOUDIFY_DEFAULT_OS_VERSION:=LTS}" && export CLOUDIFY_DEFAULT_OS_VERSION
: "${CLOUDIFY_SKIPCREDENTIALS:=false}" && export CLOUDIFY_SKIPCREDENTIALS
: "${CLOUDIFY_CREDENTIALS_DIR:="${XDG_CONFIG_HOME:-$HOME/.config}/cloudify"}" && export CLOUDIFY_CREDENTIALS_DIR
: "${CLOUDIFY_CREDENTIALS_FILE:="$CLOUDIFY_CREDENTIALS_DIR/credentials"}" && export CLOUDIFY_CREDENTIALS_FILE

#== DEBUG STATE
: "${CLOUDIFY_LOG_LEVEL:=INFO}" && export CLOUDIFY_LOG_LEVEL
: "${DEBUG:=false}" && export DEBUG
if $DEBUG && [[ "$CLOUDIFY_LOG_LEVEL" != "DEBUG" ]]; then
    export CLOUDIFY_LOG_LEVEL=DEBUG
fi

#== CLEANUP BEFORE EXIT
trap cleanup SIGINT SIGTERM ERR EXIT

#== SOURCE LIBRARY MODULES
source "$CLOUDIFY_SCRIPT_DIR/lib/utils.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/colors.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/os.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/package-api.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/credentials.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/shadow.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/containers.sh"
# shellcheck disable=SC1094
source "$CLOUDIFY_SCRIPT_DIR/lib/remote.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/packages.sh"
source "$CLOUDIFY_SCRIPT_DIR/lib/hosts.sh"

#== INITIALIZATION
function cloudify_init_paths() {
    PKG_DEBUG "Initializing Paths"

    # Ensure tmp folder exists
    [[ -d "$CLOUDIFY_TMP" ]] || mkdir -p "$CLOUDIFY_TMP"

    # Initialize log file for this session
    cloudify_init_log

    # Ensure ~/.local/bin exists and is in PATH (one-time, persisted to ~/.bashrc)
    # We use ~/.bashrc (not ~/.profile) so the PATH is available in non-login
    # SSH sessions (ssh user@host 'cmd') which never source ~/.profile.
    [[ -d "$CLOUDIFY_LOCAL_BIN" ]] || mkdir -p "$CLOUDIFY_LOCAL_BIN"
    if ! grep -qFx "# CLOUDIFY PATH END" "$HOME"/.bashrc 2>/dev/null; then
        # Insert before the interactive guard (e.g. "[ -z "$PS1" ] && return" or "case $- in")
        local _bashrc_tmp
        _bashrc_tmp=$(mktemp)
        if [[ -f "$HOME"/.bashrc ]]; then
            # Insert the PATH block before the first interactive guard line
            awk '
                !done && (/^\[ -z "\$PS1" \] && return/ || /^case \$- in/) {
                    print ""
                    print "# CLOUDIFY PATH START"
                    print "[[ \":${PATH}:\" != *\":${HOME}/.local/bin:\"* ]] && export PATH=\"${PATH}:${HOME}/.local/bin\""
                    print "# CLOUDIFY PATH END"
                    print ""
                    done=1
                }
                { print }
            ' "$HOME"/.bashrc > "$_bashrc_tmp" && mv "$_bashrc_tmp" "$HOME"/.bashrc
        else
            # No .bashrc yet — create a minimal one
            {
                echo "# CLOUDIFY PATH START"
                # shellcheck disable=SC2016
                # Intentional single quotes: $PATH and $HOME must be written as literal text into .bashrc,
                # not expanded here — they resolve when .bashrc is sourced at login.
                echo '[[ ":${PATH}:" != *":${HOME}/.local/bin:"* ]] && export PATH="${PATH}:${HOME}/.local/bin"'
                echo "# CLOUDIFY PATH END"
            } > "$HOME"/.bashrc
        fi
    fi
    # Remove stale PATH block from ~/.profile (migrated to ~/.bashrc)
    if grep -qFx "# CLOUDIFY PATH END" "$HOME"/.profile 2>/dev/null; then
        local _profile_tmp
        _profile_tmp=$(mktemp)
        awk '
            /^# CLOUDIFY PATH START/ { skip=1; next }
            /^# CLOUDIFY PATH END/   { skip=0; next }
            !skip { print }
        ' "$HOME"/.profile > "$_profile_tmp" && mv "$_profile_tmp" "$HOME"/.profile
    fi
    # shellcheck disable=SC2016
    if [[ ":${PATH}:" != *":${CLOUDIFY_LOCAL_BIN}:"* ]]; then
        export PATH="${PATH}:${CLOUDIFY_LOCAL_BIN}"
    fi
}

# Guard: ensure remote credentials are set before remote operations
function _cloudify_require_remote_creds() {
    if [[ -z "${CLOUDIFY_REMOTE_PWD+x}" ]]; then
        die "CLOUDIFY_REMOTE_PWD is not set. Run 'cloudify credentials' to set remote credentials."
    fi
    if [[ -z "${CLOUDIFY_REMOTE_USER:-}" ]]; then
        CLOUDIFY_REMOTE_USER="$(whoami)"
        export CLOUDIFY_REMOTE_USER
    fi
}

#== SUB-COMMANDS

# Check if a word is a reserved keyword
# Usage: _cloudify_is_reserved <word> [context]
# context: "global" includes --on/on/o; "action" does not
function _cloudify_is_reserved() {
    local word="${1:-}"
    local context="${2:-global}"
    case "$word" in
        --help | help | -h | --list | list | l | --credentials | credentials | c | --test | test | t)
            return 0
            ;;
    esac
    if [[ "$context" == "global" ]]; then
        case "$word" in
            --on | on | o) return 0 ;;
        esac
    fi
    return 1
}

# Check if a word is a package action keyword
function _cloudify_is_action() {
    local word="${1:-}"
    case "$word" in
        --install | install | inst | i | --uninstall | uninstall | u) return 0 ;;
    esac
    return 1
}

# Execute a package action (install/uninstall) for localhost
function _cloudify_execute_package_action() {
    local action="$1"
    shift
    local pkgs=("$@")
    cloudify_init_paths
    if [[ "$action" == "install" ]]; then
        PKG_DEBUG "${YELLOW}cloudify_install_package ${pkgs[*]}${RESET}"
        (cloudify_install_package "${pkgs[@]}") &
        _CLOUDIFY_BG_PIDS+=($!)
        is_setup_in_progress=true
    elif [[ "$action" == "uninstall" ]]; then
        PKG_DEBUG "${YELLOW}cloudify_uninstall_package ${pkgs[*]}${RESET}"
        (cloudify_uninstall_package "${pkgs[@]}") &
        _CLOUDIFY_BG_PIDS+=($!)
        is_setup_in_progress=true
    else
        die "Unexpected package action: $action"
    fi
}

# Dispatch package action to localhost or remote hosts
function _cloudify_dispatch() {
    local action="$1"
    local hosts="$2"
    local packages="$3"

    [[ "$packages" == *--install ]] && die "Cloudify usage error: Empty package section."
    [[ "$hosts" != "localhost" ]] && _cloudify_require_remote_creds

    for host in $hosts; do
        if [[ "$hosts" == "localhost" ]]; then
            local pkgs_str="${packages/--$action/}"
            pkgs_str="${pkgs_str# }"
            local -a pkgs_array
            read -ra pkgs_array <<< "$pkgs_str"
            _cloudify_execute_package_action "$action" "${pkgs_array[@]}"
        else
            PKG_DEBUG_LN "${GREEN}cloudify_remote $host $packages${RESET}"
            cloudify_remote "$host" "$packages" && is_setup_in_progress=true
        fi
    done
}

#=MAIN=
#== MAIN PARSE SCRIPT PARAMETERS
function main() {

    # Setup colors
    cloudify_setup_colors

    # Start session logging — ensures every invocation gets a log file
    export _CLOUDIFY_CMDLINE="$*"
    cloudify_init_log

    # Load credentials from XDG config file (before any cred checks)
    $CLOUDIFY_SKIPCREDENTIALS || cloudify_credentials_load

    # Map local password to unified variable (for cloudify_hostnames localhost)
    : "${CLOUDIFY_HOSTPWD:="${CLOUDIFY_LOCAL_PWD:-}"}" && export CLOUDIFY_HOSTPWD

    local hosts=""
    local packages=""

    local is_parsing_hosts=false
    local is_parsing_packages=false
    local is_setup_in_progress=false
    local -a _CLOUDIFY_BG_PIDS=()

    # No arguments given, show usage
    [[ "$#" == 0 ]] && usage && exit 0

    # Parse script parameters
    while :; do
        [[ -z "${1:-}" ]] && break
        case "$1" in
        -h | --help | help)
            usage
            break
            ;;
        -v)
            set -x
            ;;
        -n)
            export CLOUDIFY_DISABLE_COLORS=true
            cloudify_setup_colors
            ;;
        init)
            if [[ -f "$CLOUDIFY_INIT_COOKIE" ]]; then
                break
            fi
            cloudify_init_paths
            command -v rsync >/dev/null 2>&1 || cloudify_install_package rsync
            # shellcheck source=/dev/null
            if ! source "$CLOUDIFY_DIR"/pkg/askpassstars/present.sh 2>/dev/null; then
                SKIPDONEMESSAGE=true cloudify_install_package askpassstars
                $CLOUDIFY_SKIPCREDENTIALS || cloudify credentials
            fi
            touch "$CLOUDIFY_INIT_COOKIE"
            break
            ;;
        hosts | hst)
            shift
            CLOUDIFY_SKIPCREDENTIALS=true cloudify_init_paths
            if [[ -z "${1-}" || "${1-}" == "@all" ]]; then
                cloudify_list_hosts_by_tags
            else
                cloudify_list_hosts_by_tags "$@"
            fi
            break
            ;;
        packages | pkg)
            shift
            CLOUDIFY_SKIPCREDENTIALS=true cloudify_init_paths
            if [[ "${1-}" == "show" ]]; then
                shift && cloudify_print_package_recipe "$@"
            elif [[ -z "${1-}" || "${1-}" == "@all" ]]; then
                cloudify_list_packages_by_tags | column 2>/dev/null || cloudify_list_packages_by_tags
            else
                cloudify_list_packages_by_tags "$@"
            fi
            break
            ;;
        launch | run)
            local host="$2"
            local host_image="${3:-}"
            local restparams="${*:4}"

            # shellcheck disable=SC2086
            cloudify_container_launch "$host" ${host_image:+"$host_image"} $restparams
            hostip=$(cloudify_container_ip "$host")
            log_info "Container $host IP: $hostip"
            break
            ;;
        delete | del)
            host="$2"
            if ! cloudify_container_delete "$host" "${@:3}" --force; then die "Error deleting $host. Are you sure the host exists?"; fi
            break
            ;;
        shell | sh)
            _cloudify_require_remote_creds
            [[ -z "${2:-}" ]] && die "Missing host"
            shift
            local host="$1"
            shift

            local ssh_target="${CLOUDIFY_REMOTE_USER:+$CLOUDIFY_REMOTE_USER@}$host"

            if [[ $# -eq 0 ]] || [[ "${1:-}" == "-i" ]]; then
                if [[ "${1:-}" == "-i" ]]; then
                    shift
                    # -i explicitly requests interactive: always use -t
                    ssh -t -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" -o "ConnectTimeout=10" "$ssh_target" "$@"
                else
                    # Bare shell: use -t only when stdin is a TTY
                    local tty_flag=""
                    [ -t 0 ] && tty_flag="-t"
                    ssh $tty_flag -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" -o "ConnectTimeout=10" "$ssh_target" "$@"
                fi
            else
                # Non-interactive: pipe output, strip SSH banner
                ssh -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" -o "ConnectTimeout=10" "$ssh_target" "$@" 2>&1 | tail -n +2
            fi
            ;;
        execute | exec)
            shift
            [[ -z $1 ]] && die "Missing host"
            local host="$1"
            shift
            if [[ $host == "localhost" ]]; then
                # =Note= Intentional command execution via 'execute' subcommand
                bash -c "$*"
            else
                _cloudify_require_remote_creds
                cloudify_remote_sync "$host" exec localhost "\"$*\""
            fi
            break
            ;;
        credentials | crd)
            case "${2:-}" in
                --check)
                    cloudify_credentials_load
                    cloudify_credentials_check
                    ;;
                remote | github | gitlab)
                    cloudify_credentials_setup "$2"
                    ;;
                "")
                    cloudify_credentials_setup
                    ;;
                *)
                    die "Unknown credentials subcommand: $2"
                    ;;
            esac
            break
            ;;
        info)
            shift && cloudify_info "$@"
            break
            ;;
        hostnames | hsn)
            PKG_DEBUG "In cloudify, Running: " cloudify_hostnames "$@"
            shift && cloudify_hostnames "$@"
            break
            ;;
        --on)
            # Build hosts list
            [[ $is_parsing_packages == "started" ]] && die "Cloudify usage error: unexpected on block."
            [[ $is_parsing_hosts == "started" ]] && die "cloudify usage error: 'on' statement already encountered"

            is_parsing_hosts="started"
            packages=""
            hosts=""

            while true; do
                _cloudify_is_reserved "${2:-}" "global" && die "Argument syntax error: '$2' invalid inside an 'on' block"

                local is_end=false
                [[ -z "${2:-}" || "${2:-}" == -* ]] && is_end=true
                _cloudify_is_action "${2:-}" && is_end=true
                if "$is_end"; then
                    [[ -z "$hosts" ]] && die "Cloudify usage error: No host found."
                    is_parsing_hosts="ended"
                    break
                fi
                local hosts_to_add="${2:-}"
                [[ "${2:-}" == @* ]] && hosts_to_add=$(cloudify_list_hosts_by_tags "$2")

                if [[ -z "$hosts" ]]; then
                    hosts="$hosts_to_add"
                else
                    hosts="$hosts $hosts_to_add"
                fi
                shift
            done
            [[ -z "${2:-}" ]] && die "No packages found for hosts: $hosts"
            ;;
        --install | install | inst | i | --uninstall | uninstall | u)
            [[ $is_parsing_hosts == "started" ]] && die "Cloudify usage error: unexpected action '$1'"
            [[ -z "$hosts" ]] && hosts="localhost"
            is_parsing_packages="started"

            local action=''
            case "$1" in
            --install | install | inst | i)
                action='install'
                ;;
            --uninstall | uninstall | u)
                action='uninstall'
                ;;
            esac

            [[ -z "$packages" ]] && packages="--$action" || packages="$packages --$action"

            while true; do
                _cloudify_is_reserved "${2:-}" "action" && die "Argument syntax error: '$2' invalid inside an action block."

                _cloudify_is_action "${2:-}" && {
                    [[ "$hosts" == "localhost" ]] && {
                        _cloudify_dispatch "$action" "$hosts" "$packages"
                        packages=""
                    }
                    break
                }

                [[ -z "${2:-}" || "${2:-}" == "--on" || "${2:-}" == "on" || "${2:-}" == "o" ]] && {
                    is_parsing_packages="ended"
                    _cloudify_dispatch "$action" "$hosts" "$packages"
                    break
                }
                packages="$packages ${2:-}"
                shift
            done
            ;;
        -?*) die "Error: Unknown option '$1'" 1 ;;
        *) die "Error: Unknown argument '$1'. Did you mean 'cloudify $1 shell'?" 1 ;;
        esac
        shift
    done

    # Print Setup in progress only if we launched background setup
    $is_setup_in_progress && {
        msg "${GREEN}Setup of machines in progress...${RESET}"

        local had_failures=false
        for _bg_pid in "${_CLOUDIFY_BG_PIDS[@]}"; do
            if ! wait "$_bg_pid"; then
                had_failures=true
            fi
        done

        if $had_failures; then
            msg "${RED}Setup completed with errors. Log: ${CLOUDIFY_LOG_FILE:-}${RESET}"
        else
            msg "${GREEN}Setup Done.${RESET}"
        fi
    }
    return 0
}

#== MAIN: EXECUTE SCRIPT!
main "$@"
