# Workstation installation
# =warning= this script must be SOURCED and not executed  (otherwise environment modifcations, like aliases, won't persist after exectution)
# =todo= Modify the script so it can be executed: all environment variables and aliases that must persist be set by bash-it 

# DEBUG or NOT
export WRKFY_DEBUG=true

function WRKFY_DEBUG_MSG() {
  $WRKFY_DEBUG && echo -e "*** DEBUG: $1 ***"
}
function WRKFY_DEBUG_MSG_NEWLINE() {
  $WRKFY_DEBUG && echo -e "\n*** DEBUG: $1 ***"
}


function wrkfy_pkg_startup(){

  WRKFY_DEBUG_MSG_NEWLINE "ENV TO SETUP:"
  WRKFY_PKG_ENV_ESCAPED=()
  for wrkfy_line in "${WRKFY_PKG_ENV[@]}"; do
    echo "Adding $wrkfy_line to array"
    wrkfy_line=$(echo "$wrkfy_line" | sed 's/\//\\\//g' )
    WRKFY_PKG_ENV_ESCAPED+=( "$wrkfy_line" )
  done;
  #WRKFY_PKG_ENV_ESCAPED=$(echo "$WRKKFY_PKG_ENV" | sed 's/\//\\\//g')
  WRKFY_DEBUG_MSG_NEWLINE "ENV TO SETUP:"
  for wrkfy_line in "${WRKFY_PKG_ENV_ESCAPED[@]}"; do
    echo "Added $wrkfy_line"
  done;
  
  # Reserve workit space in bashrc
  WRKFY_DEBUG_MSG_NEWLINE "Reserve Workify space inside bashrc"
  grep -qFx "# WORKIT ENV START" ~/.bashrc || echo -e "# WORKIT ENV START\n# WORKIT ENV END"  >> ~/.bashrc
  
  # Remove previous pkg setup
  WRKFY_DEBUG_MSG_NEWLINE "Remove existing pkg setup if any"
  for wrkfy_line in "${WRKFY_PKG_ENV_ESCAPED[@]}"; do
    WRKFY_DEBUG_MSG "Remove line: $wrkfy_line"
    sed -in "/$wrkfy_line/d" ~/.bashrc
    WRKFY_DEBUG_MSG "----"
    WRKFY_DEBUG_MSG "What's in there in bashrc?"
    tail ~/.bashrc
    echo 
  done;
  
  
  
  # Insert bash-it env
  WRKFY_DEBUG_MSG_NEWLINE "Inserting pkg setup"
  for wrkfy_line in "${WRKFY_PKG_ENV_ESCAPED[@]}"; do
    WRKFY_DEBUG_MSG "Inserting line: $wrkfy_line"
    sed -in "/# WORKIT ENV END/i $wrkfy_line" ~/.bashrc
    WRKFY_DEBUG_MSG "----"
    WRKFY_DEBUG_MSG "What's in there in bashrc?"
    tail ~/.bashrc
    echo
  done;
  
}

# Install apt package if not already installed
function WRKFY_APT_INSTALL() {
  for pkg in ${@}; do 
   dpkg -l "$pkg" |& grep -q "^ii  $pkg" || WRKFY_DEBUG_MSG_NEWLINE "Installing $pkg apt package" && sudo apt-get -q install "$pkg"  -y
  done
}

# Adds a package dependeny
function WRKFY_PKG_DEPS() {
  for pkg in ${@}; do 
    WRKFY_DEBUG_MSG "Installing $pkg workify package"
    source "$WRKFY_DIR"/pkg/"$pkg"/init.sh
  done
}


# Local Configuration variables

# To find workify/pkg directory path we naively relied on the following line to retrieve the path of the folder containing this script
# Since then workify, the script, has been extracted from workify, the packages repo, into its own project
# So we had to hardcode the path to workify/pkg (with an environment variable to customize that path)
# WRKFY_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
# Set WRKFY_DIR a defautl value if not already set
: "${WRKFY_DIR:=$HOME/workify}"
# The variable is needed in subshells
export WRKFY_DIR

# Create local tmp folder 
LOCAL_TMP=~/tmp/
[[ -d "$LOCAL_TMP" ]] || mkdir -p "$LOCAL_TMP"

# Make sure vim is the default editor 
export EDITOR=vim                           # If an editor is needed during install 

# Make sure ~/.local/bin exists and is in the path
LOCAL_BIN=~/.local/bin
[[ -d "$LOCAL_BIN" ]] || mkdir -p "$LOCAL_BIN"
#[[ ":${PATH}:" != *":${LOCAL_BIN}:"* ]] && export PATH="${LOCAL_BIN}:${PATH}"
# Make it persistent 
#echo [[ ":${PATH}:" != *":${LOCAL_BIN}:"* ]] && export PATH="${LOCAL_BIN}:${PATH}" >> ~/.bashrc


# Are we on Android Termux or Linux station?
if [ ! -z "$(pgrep -f com.termux)" ]; then
  WRKFY_TERMUX=true
  WRKFY_PKG_FILE=${WRKFY_DIR}/termux.packages
else
  WRKFY_PKG_FILE=${WRKFY_DIR}/station.packages
fi
WRKFY_PKG_INIT="init.sh"
WRKFY_PKG_INIT_TERMUX="termux.init.sh"


function printHelp(){
cat << EOF
usage: cloudify:                    print help
       cloudify help:               print help  
       cloudify ls|list:            list installable packages 
       cloudify ls|list default:    list default packages 
       cloudify i <pkg>             install package
       cloudify i default           install default in termux|station.packages
       cloudify u <pkg>             uninstall package
EOF
}

function printDone() {
  echo -e "\nNow please Source ~/.bashrc\n***"
  echo -e "Station on orbit!\n***"
}

# Install packages

if [[ -z "$1" || "$1" == "help" ]] ; then
  # Get help 
  printHelp
elif [[ ( "$1" == "ls" || "$1" == "list" ) && "$2" == "default" ]]; then
  # List default packages for current platform
  # Default packages are lited in ./*.packages files 
  ( for pkg in $(< ${WRKFY_PKG_FILE}); do
      echo ${pkg%%*( )}
    done ) | column 
elif [[ ( "$1" == "ls" || "$1" == "list" ) && ( -z "$2" || "$2" == "all" ) ]]; then
  # List all available packages for current platform
  \ls "$WRKFY_DIR"/pkg
elif [[ ( "$1" == "i" || "$1" == "install" ) &&  "$2" == "default" ]]; then
  # Install default packages for current platform 
  # Default packages are lited in ./*.packages files 
  for pkg in $(< ${WRKFY_PKG_FILE}); do
    WRKFY_DEBUG_MSG "Installing ${pkg%%*( )}"
    if [[ $WRKFY_TERMUX && -f "$WRKFY_PKG_INIT_TERMUX" ]]; then
        source "$WRKFY_DIR"/pkg/${pkg%%*( )}/${WRKFY_PKG_INIT_TERMUX}            # We use bash expansion to trim spaces at the end of the package name
    else
        source "$WRKFY_DIR"/pkg/${pkg%%*( )}/${WRKFY_PKG_INIT}                          # We use bash expansion to trim spaces at the end of the package name
    fi
  done
  printDone
elif [[ ( "$1" == "i" || "$1" == "install" ) &&  ! -z "$2" ]]; then
  # Install a specific package
  pkg="$2"
  WRKFY_DEBUG_MSG "Installing ${pkg%%*( )}"
  if [[ $WRKFY_TERMUX && -f "$WRKFY_PKG_INIT_TERMUX" ]]; then
    source "$WRKFY_DIR"/pkg/${pkg%%*( )}/${WRKFY_PKG_INIT_TERMUX}            # We use bash expansion to trim spaces at the end of the package name
  else
    source "$WRKFY_DIR"/pkg/${pkg%%*( )}/${WRKFY_PKG_INIT}                          # We use bash expansion to trim spaces at the end of the package name
  fi
  printDone
else
  # Get help 
  printHelp
fi

