# =TODO= Use envsubst instead of replacing env variables one by one!
# For some sub-commands (eg. $ cloudify exec ...), we need synchronous exection
function cloudify_remote_sync() {

    # When you run "cloudify host1 cmd", the command shouldn't be allowed to call "cloudify host2 cmd2"
    # =todo= Actually it's a nice feature to have as it allows bastion hosts
    #        We should be able to call 'cloudify host1 host2 host3 cmd' and have cloudify call recursively itself
    #        This requires ssh keys, user and sudo password management capability
    #        One solution would be to have these informations stored in the inventory folder, and passed recursively from one cloudify call to the next
    local host="$1" && shift
    $CLOUDIFY_IS_LOCAL || [[ "$host" == "localhost" ]] || die "Cloudify is already running on a remote host. Can't call cloudify remotely on another host."

    # =todo= Currenty credentials (ssh key, sudo user, sudo password) are limited:
    #           - The remote user is unique and given by an env variable (CLOUDIFY_REMOTE_USER)
    #           - The remote user password is unique and given by an env variable (CLOUDIFY_REMOTE_PWD)
    #           - The ssh key is the default one of the user calling cloudify  (~/.ssh/id_rsa.pub)
    #        We need  more flexibility. Each host in the inventory should have its own ssh key, user and password
    #        This is where these credentials shoud be retrieved from the inventory directory

    if [[ "$host" == "localhost" ]]; then
        PKG_DEBUG executing cloudify $@
        cloudify $@ |& sed "s/^/$host: /" |& sed "s/^$host: $//"
    else

        # Read remote payload template
        local cloudify_remote_payload=$(declare -f cloudify_remote_payload_template | tail -n +3 | head -n -1)

        # Load credentials in the payload template
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_DISABLE_COLORS}}/$CLOUDIFY_DISABLE_COLORS/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{DEBUG}}/$DEBUG/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_FORCE_UPDATE}}/$CLOUDIFY_FORCE_UPDATE/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_UPDATE_DELAY}}/$CLOUDIFY_UPDATE_DELAY/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_REMOTE_USER}}/$CLOUDIFY_REMOTE_USER/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_REMOTE_PWD}}/$CLOUDIFY_REMOTE_PWD/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITHUBUSER}}/$CLOUDIFY_GITHUBUSER/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITHUBPWD}}/$CLOUDIFY_GITHUBPWD/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITLABUSER}}/$CLOUDIFY_GITLABUSER/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITLABPWD}}/$CLOUDIFY_GITLABPWD/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_RCLONE_REMOTE}}/$CLOUDIFY_RCLONE_REMOTE/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_RCLONE_REMOTE_REGION}}/$CLOUDIFY_RCLONE_REMOTE_REGION/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_RCLONE_REMOTE_ENDPOINT}}/$CLOUDIFY_RCLONE_REMOTE_ENDPOINT/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_RCLONE_REMOTE_ACCESSKEYID}}/$CLOUDIFY_RCLONE_REMOTE_ACCESSKEYID/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{CLOUDIFY_RCLONE_REMOTE_SECRETACCESSKEY}}/$CLOUDIFY_RCLONE_REMOTE_SECRETACCESSKEY/g" <<<"$cloudify_remote_payload")
        cloudify_remote_payload=$(sed "s/{{RESTIC_PASSWORD}}/$RESTIC_PASSWORD/g" <<<"$cloudify_remote_payload")

        # Add actual cloudify command (plus force output colorization as cloudify won't colorize output when running
        cloudify_remote_payload="$cloudify_remote_payload; cloudify $@"

        PKG_DEBUG "Payload to execute remotely on $host:"
        # Passwords are replaved by asterisks before printing
        # HACK! Password are recognized only if env variable ends with 'PWD', contains 'PASSWORD' or contains 'SECRET'
        local cloudify_remote_payload_secure="$(sed 's/PWD='\''\(.*\)'\''/PWD='\''***********'\''/g' <<<$cloudify_remote_payload)"
        cloudify_remote_payload_secure="$(sed 's/PASSWORD\(.*\)='\''\(.*\)'\''/PASSWORD\1='\''***********'\''/g' <<<$cloudify_remote_payload_secure)"
        cloudify_remote_payload_secure="$(sed 's/SECRET\(.*\)='\''\(.*\)'\''/SECRET\1='\''***********'\''/g' <<<$cloudify_remote_payload_secure)"

        $DEBUG && msg "$cloudify_remote_payload_secure"

        PKG_DEBUG "SSHing..."
        # The SSH session is launched in the background to parallelize hosts cloudifcation
        # =TODO= Remote hosts key checking has been totally disabled.
        #        It's highly unsafe! Parse ssh messages and prompt the user for decision instead.
        ssh -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" $host "$cloudify_remote_payload" |& sed "s/^/$host: /" |& sed "s/^$host: $//" |& tail -n +2
    fi
}

