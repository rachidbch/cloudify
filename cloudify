# Test code that can be tested w/ 'cloudify test'
# Use this to test code before inserting it in cloudify

function cloudify_piped() {
    local lineargs=""
    local pipeargs=""

    # Find out if cloudify command have been called within a pipe, with arguments or both
    # This if incantation can of course be simplified but I prefer to let it that way to make the different cases clearer

    if [ -t 0 ]; then
        # 'sudo' not called in a pipe
        : # Do nothing
        #lineargs="$lineargs"
    elif [[ -p /dev/stdin ]]; then
        # 'sudo' called in a pipe.
        pipeargs="$(cat -)"
    else
        # 'sudo' called with a here doc
        pipeargs="$(cat -)"
    fi

    if [[ -z $pipeargs ]]; then
        cloudify_cmd="$lineargs"
    else
        cloudify_cmd="echo '$pipeargs' | $lineargs"
    fi

    # As we pass everything, including piped input as arguments to 'bash -c', we can safely supply sudo password using a herestring
    cloudify_cmd_length=$(echo -n "'$cloudify_cmd'" | wc -m)

    if (($cloudify_cmd_length < 10000)); then
        PKG_DEBUG ""
    else
        # The sudo command is much too long, create a temporary file and execute it
        local tfile=$(mktemp /tmp/foo.XXXXXXXXX)
        echo creating $tfile
        echo "$pipeargs" >$tfile
        PKG_DEBUG command sudo -kS "$lineargs" "$tfile" \<\<\< "$password"
        command sudo -p " " -kS "$lineargs" "$tfile" <<<"$password"
    fi
}

