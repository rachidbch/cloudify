# Check if needed credentials are set in appropriate environment  variables
# If not, ask for credentials and generate a script that the user will source to set the environment variables

function check_credentials () {
  # Check for credentials environment variables 
  ## sudo user and password, gitlab and github user and password must be set in env variables 
  [[ "${1-}" == "-f" || "${1-}" == "--force" ]] && local force_ask_credentials=true || local force_ask_credentials=false

  local new_credentials=false

  if "$force_ask_credentials" || [[ -z "${CLOUDIFY_LOCALHOSTUSER-}" || -z "${CLOUDIFY_LOCALHOSTPWD-}" || -z "${CLOUDIFY_HOSTUSER-}" || -z "${CLOUDIFY_HOSTPWD-}" ||  -z "${CLOUDIFY_GITHUBUSER-}" || -z "${CLOUDIFY_GITHUBPWD-}" || -z "${CLOUDIFY_GITLABUSER-}" || -z "${CLOUDIFY_GITLABPWD-}" ]]; then
    local new_credentials=true
    msg "${GREEN}Cloudify needs your Host, Github and Gitlab credentials.${RESET}"
    [[ -f /dev/shm/cloudify_credentials ]] && rm -f "/dev/shm/cloudify_credentials"
    touch /dev/shm/cloudify_credentials 
    chmod 600 /dev/shm/cloudify_credentials
  fi

  # Ensure local host user is set
  if "$force_ask_credentials" || [[ -z "${CLOUDIFY_LOCALHOSTUSER-}" || -z "${CLOUDIFY_LOCALHOSTPWD-}" ]]; then
    ask_localhost_credentials
    echo "export CLOUDIFY_LOCALHOSTUSER=$CLOUDIFY_LOCALHOSTUSER" >> /dev/shm/cloudify_credentials
    echo "export CLOUDIFY_LOCALHOSTPWD=$CLOUDIFY_LOCALHOSTPWD" >> /dev/shm/cloudify_credentials
  fi

  # Ensure remote host user is set
  if "$force_ask_credentials" || [[ -z "${CLOUDIFY_HOSTUSER-}" || -z "${CLOUDIFY_HOSTPWD-}" ]]; then
    ask_host_credentials
    echo "export CLOUDIFY_HOSTUSER=$CLOUDIFY_HOSTUSER" >> /dev/shm/cloudify_credentials
    echo "export CLOUDIFY_HOSTPWD=$CLOUDIFY_HOSTPWD" >> /dev/shm/cloudify_credentials
  fi

  # Ensure remote Github user is set
  if "$force_ask_credentials" ||  [[ -z "${CLOUDIFY_GITHUBUSER-}" || -z "${CLOUDIFY_GITHUBPWD-}" ]]; then
    ask_github_credentials
    echo "export CLOUDIFY_GITHUBUSER=$CLOUDIFY_GITHUBUSER" >> /dev/shm/cloudify_credentials
    echo "export CLOUDIFY_GITHUBPWD=$CLOUDIFY_GITHUBPWD" >> /dev/shm/cloudify_credentials
  fi

  # Ensure remote Gitlab host user is set
  if "$force_ask_credentials" ||  [[ -z "${CLOUDIFY_GITLABUSER-}" || -z "${CLOUDIFY_GITLABPWD-}" ]]; then
    ask_gitlab_credentials
    echo "export CLOUDIFY_GITLABUSER=$CLOUDIFY_GITLABUSER" >> /dev/shm/cloudify_credentials
    echo "export CLOUDIFY_GITLABPWD=$CLOUDIFY_GITLABPWD" >> /dev/shm/cloudify_credentials
  fi
  
  if "$new_credentials"; then 
    echo
    msg "${GREEN}A script was generated to store these credentials in environment variables.${RESET}"
    msg "${GREEN}Please execute the following command line:${RESET}"
    msg "source /dev/shm/cloudify_credentials"
  fi
}


#== SHADOWING !
##  Cloudify shadows some bash commands and programs to ensure seamless operations (auto-authentication, idempotence, etc)
##  This way, package init scripts can be naive bash scripts while cloudify ensures high reliability, remote execution, etc


## Sudo Shadowing
#  To call commands requiring password based authentication, we generally supply the password (that is stored in CLOUDIFY_HOSTPWD or CLOUDIFY_LOCALHOSTPWD variable)
#  using a Here String (which uses stdin). Sudo command stdin is often used for normal command processing (like in 'echo <commands> | sudo tee ...') 
#  So to suppy the password to sudo we need to rearrange the way sudo is called, passing everything as arguments to free stdin for password

function sudo() {

  local lineargs=""
  local pipeargs="" 

  if [ -t 0 ]; then
    lineargs="${@}"
  elif [[ -p /dev/stdin ]]; then
    lineargs="${@}"
    pipeargs="$(cat -)"
  else
    lineargs="${@}"
    pipeargs="$(cat -)"
  fi

  if [[ -z $pipeargs ]]; then
    sudocmd="$@"
  else
    sudocmd="echo '$pipeargs' | $lineargs"
  fi

  # As we pass everything, including piped input as arguments to 'bash -c', we can safely supply sudo password using a herestring
  command sudo -kS bash -c "$sudocmd"  &>/dev/null <<< "$CLOUDIFY_HOSTPWD"
}


## Git shadowing

function git_authenticate() {
  local git_remote_url="${1-}"
  [[ -z "${git_remote_url-}" ]] && PKG_DEBUG "Remote url must be non null." return 1


  # first backup current .gitconfig
  pkg_backup "$HOME"/.gitconfig 

  # Only credentials per git domain are supported so far 
  # =TODO= Enable credential per account and per project. 
  local git_domain=$(parse_git_url $git_remote_url domain) 

  case "${git_domain-}" in
     gitlab.com)  
        export GIT_TOKEN=$CLOUDIFY_GITLABPWD
        ;; 
     github.com)  
        export GIT_TOKEN=$CLOUDIFY_GITHUBPWD
        ;; 
     *) die "Git Host $git_domain is not supported'" 1;;
  esac
  echo 'echo $GIT_TOKEN' > $HOME/.git-askpass
  chmod +x $HOME/.git-askpass
  export GIT_ASKPASS=$HOME/.git-askpass

  # use 'insteadOf' git feature to force git to use https connection whatever the git url format used
  command git config --global url."https://api@${git_domain}/".insteadOf "https://${git_domain}/"
  command git config --global url."https://ssh@${git_domain}/".insteadOf "ssh://git@${git_domain}/"
  command git config --global url."https://git@${git_domain}/".insteadOf "git@${git_domain}:"

# git config --global url."https://api@github.com/".insteadOf "https://github.com/"
# git config --global url."https://ssh@github.com/".insteadOf "ssh://git@github.com/"
# git config --global url."https://git@github.com/".insteadOf "git@github.com:"

}

function git_deauthenticate() {

  # Undo our git config modifications 
  pkg_restore "$HOME"/.gitconfig 
}

# Does two remote url refer to the same remote repo? 
function same_git_remote () {
    local remote_url_1="${1-}"
    local remote_url_2="${2-}"

    local url_1; local url_2;
    local host_1;  local host_2; 
    local domain_1;  local domain_2; 
    local subdomain_1;  local subdomain_2; 
    local port_1; local port_2; 
    local account_1;  local account_2; 
    local project_1;  local project_2; 
  
    local _; local segment


    #parse_git_url "${remote_url_1}" 

    # Parsing the output of 'parse_git_utl' to get individual url segments. So meta :)
    # Note without the 'IFS=' prefix, read discards leading and trailing whitespaces. But we need them to correctly parse the segments
    parse_git_url "${remote_url_1}" | {
        IFS= read url_1; segment=$(echo $url_1 | cut -d: -f1); url_1=${url_1#$segment: }
        IFS= read _
        IFS= read _
        IFS= read _
        IFS= read _
        IFS= read host_1;  segment=$(echo $host_1 | cut -d: -f1); host_1=${host_1#$segment: }
        IFS= read domain_1;  segment=$(echo $domain_1 | cut -d: -f1); domain_1=${domain_1#$segment: }
        IFS= read subdomain_1; segment=$(echo $subdomain_1 | cut -d: -f1); subdomain_1=${subdomain_1#$segment: } 
        IFS= read port_1;  segment=$(echo $port_1 | cut -d: -f1); port_1=${port_1#$segment: }
        IFS= read _
        IFS= read account_1;  segment=$(echo $account_1 | cut -d: -f1); account_1=${account_1#$segment: }
        IFS= read project_1;  segment=$(echo $project_1 | cut -d: -f1); project_1=${project_1#$segment: }
  
        #IFS= echo url_1 $url_1
        #IFS= echo host_1 $host_1
        #IFS= echo domain_1 $domain_1
        #IFS= echo subdomain_1 $subdomain_1
        #IFS= echo port_1 $port_1
        #IFS= echo account_1 $account_1
        #IFS= echo project_1 $project_1

        parse_git_url "${remote_url_2}" | {
            IFS= read url_2; segment=$(echo $url_2 | cut -d: -f1); url_2=${url_2#$segment: }
            IFS= read _
            IFS= read _
            IFS= read _
            IFS= read _
            IFS= read host_2;  segment=$(echo $host_2 | cut -d: -f1); host_2=${host_2#$segment: }
            IFS= read domain_2;  segment=$(echo $domain_2 | cut -d: -f1); domain_2=${domain_2#$segment: }
            IFS= read subdomain_2; segment=$(echo $subdomain_2 | cut -d: -f1); subdomain_2=${subdomain_2#$segment: } 
            IFS= read port_2;  segment=$(echo $port_2 | cut -d: -f1); port_2=${port_2#$segment: }
            IFS= read _
            IFS= read account_2;  segment=$(echo $account_2 | cut -d: -f1); account_2=${account_2#$segment: }
            IFS= read project_2;  segment=$(echo $project_2 | cut -d: -f1); project_2=${project_2#$segment: }
  
            #IFS= echo url_2 $url_2
            #IFS= echo host_2 $host_2
            #IFS= echo domain_2 $domain_2
            #IFS= echo subdomain_2 $subdomain_2
            #IFS= echo port_2 $port_2
            #IFS= echo account_2 $account_2
            #IFS= echo project_2 $project_2

            [[ $url_1 == $url_2 ]] && [[ $host_1 == $host_2 ]] && [[ $domain_1 == $domain_2 ]] && [[ $subdomain_1 == $subdomain_2 ]] && [[ $port_1 == $port_2 ]] && [[ $account_1 == $account_2 ]] && [[ $project_1 == $project_2 ]] &&  return 0;
            return 1;
        }
    }
}


function git() {

  # Then   
  local inside_git_repo=false
  local git_remote_url=""
  if [[ "${1-}" == "clone" ]];then
     # We need to get the remote git host by parsing arguments passed to 'git clone'  
     # Any argument that isn't clone or an option, is deemed to be the url to clone
     for arg in "$@"; do
       [[ "${arg-}" != "clone" &&  "${arg-}" != "-*" ]] && { 
         if [[ -z "${git_remote_url}" ]] && is_git_url "${arg-}"; then 
           git_remote_url="${arg-}"
         else
           [[ -z "{git_remote_url}" ]] && { PKG_DEBUG "Unable to git clone: Not a valid git url" &&  return 1; }
           git_repo_path="${arg-}"
           # No validity test here as anything can be a path on linux
           # But we can only clone into an existing folder
           [[ ! -d $(dirname "${arg-}") ]] &&  { PKG_DEBUG "Unable to git clone: path $(dirname ${arg-}) doesn't exist." &&  return 1; }
           break
         fi   
       } 
     done 
     # If the directory exist, we simply update 
     
     # nul 
     # Continue: git will create a sub folder in pwd

     # Not not null, dir doesn't exist
     # Continue: git will create the dir 

     # not null, dir exist. dir  is empty 
     # Continue: git will fill the dir
      
     # not null, dir exist. dir NOT empty 
     # WARNING: if git_repo_url is the same, PULL!
     #          if git_repo_url is not the same. ERROR!

     if [[ -d "$git_repo_path" ]] && ! emptydir "$git_repo_path"; then
       PKG_DEBUG "$git_repo_path directory exist and isn't empty. Pulling updates." 
       ( cd "$git_repo_path"
         inside_git_repo="$(command git rev-parse --is-inside-work-tree 2>/dev/null)"
         $inside_git_repo || { PKG_DEBUG "Can't execute git commands. $git_repo_path isn't a git repo" && return 1; }
         
         if same_git_remote ${git_remote_url} $(command git remote get-url origin); then
             #set -x
             git pull
             #set +x
         else
            PKG_DEBUG "Unable to git clone: Repo $(command git remote get-url origin) different from $git_remote_url you trying to clone." &&  return 1 
         fi
       )
     else
         PKG_DEBUG "$git_repo_path doesn't exist directory exist or is empty. cloning" 
         git_authenticate $git_remote_url
         #set -x
         command git "$@" -v
         #set +x
         git_deauthenticate $git_remote_url
     fi
  else
     # We can directly read remote url 
     inside_git_repo="$(command git rev-parse --is-inside-work-tree 2>/dev/null)"
     if [[ ! "$inside_git_repo" ]]; then
        PKG_DEBUG "Can't execute git commands. $PWD is not inside a git repo."
        return 1
     else
        git_remote_url=$(command git remote get-url origin)
        PKG_DEBUG "Git remote URL: $git_remote_url"
     fi
     git_authenticate $git_remote_url
     PKG_DEBUG "Actual git command executed:" echo git "$@" -v
     #set -x
     command git "$@" -v
     #set +x
     git_deauthenticate $git_remote_url
  fi
}


#== REMOTING
##  Cloudify can execute cloudify package init scripts on remote machine

function cloudify_remote_payload_template() {
  export CLOUDIFY_DEBUG='{{CLOUDIFY_DEBUG}}'
  export CLOUDIFY_HOSTUSER='{{CLOUDIFY_HOSTUSER}}'
  export CLOUDIFY_HOSTPWD='{{CLOUDIFY_HOSTPWD}}'
  export CLOUDIFY_GITHUBUSER='{{CLOUDIFY_GITHUBUSER}}'
  export CLOUDIFY_GITHUBPWD='{{CLOUDIFY_GITHUBPWD}}'
  export CLOUDIFY_GITLABUSER='{{CLOUDIFY_GITLABUSER}}'
  export CLOUDIFY_GITLABPWD='{{CLOUDIFY_GITLABPWD}}'

  bash -c "$(curl -sL scripts.rachid.space/bootstrap/cloudify.sh)"
}

function cloudify_remote() {
  #local host="$1" && shift
  local host="$1" && shift

  if [[ "$host" == "localhost" ]]; then
      cloudify $@  |& sed "s/^/$host: /"  |& sed "s/^$host: $//"
  else
      # Read remote payload template
      local cloudify_remote_payload=$(declare -f cloudify_remote_payload_template | tail -n +3 | head -n -1)
     
      # Load credentials in the payload template
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_DEBUG}}/$CLOUDIFY_DEBUG/g" <<< "$cloudify_remote_payload")
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_HOSTUSER}}/$CLOUDIFY_HOSTUSER/g" <<< "$cloudify_remote_payload")
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_HOSTPWD}}/$CLOUDIFY_HOSTPWD/g" <<< "$cloudify_remote_payload")
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITHUBUSER}}/$CLOUDIFY_GITHUBUSER/g" <<< "$cloudify_remote_payload")
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITHUBPWD}}/$CLOUDIFY_GITHUBPWD/g" <<< "$cloudify_remote_payload")
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITLABUSER}}/$CLOUDIFY_GITLABUSER/g" <<< "$cloudify_remote_payload")
      cloudify_remote_payload=$(sed "s/{{CLOUDIFY_GITLABPWD}}/$CLOUDIFY_GITLABPWD/g" <<< "$cloudify_remote_payload")
    
      # Add actual cloudify command (plus force output colorization as cloudify won't colorize output when running 
      cloudify_remote_payload="export CLOUDIFY_FORCE_COLORS=true;\n$cloudify_remote_payload; cloudify $@"
    
      PKG_DEBUG "Payload to execute remotely on $host:" 
      # Passwords are replaved by asterisks before printing
      # HACK! Password are recognized only if env variable ends with 'PWD'...
      $CLOUDIFY_DEBUG && msg  "$(sed 's/PWD='\''\(.*\)'\''/PWD='\''***********'\''/g' <<< $cloudify_remote_payload)"

      PKG_DEBUG "SSHing..."
      # The SSH session is launched in the background to parallelize hosts cloudifcation
      # =TODO= Remote hosts key checking has been totally disabled.
      #        It's highly unsafe! Parse ssh messages and prompt the user for decision instead. 
      (ssh -o "UserKnownHostsFile=/dev/null" -o "StrictHostKeyChecking=no" $host "$cloudify_remote_payload" |& sed "s/^/$host: /"  |& sed "s/^$host: $//") &
      #ssh -tt workify "sudo -kS cat /etc/shadow" <<< "$CLOUDIFY_HOSTPWD"
  fi
} 





