#== SCRIPT USAGE
function usage(){
cat <<'EOF'
  cloudify [action] [package]
  examples:
       cloudify help                                   print this usage help 
       cloudify init                                   Initilize cloudify before use (required once per session)
       cloudify --credentials|credentials|c            Sets credentials (local host, remote hosts, github, gitlab)
       cloudify packages|pkgs                          list installable packages 
       cloudify packages|pkgs default                  list default packages 
       cloudify --install|install|i <pkg>              install package on local machine
       cloudify --install|install|i default            install default packages on local machine
       cloudify --uninstall|uninstall|u <pkg>          uninstall package
       cloudify hosts                                  list remote hosts
       cloudify host <host>                            print <host> remote host status
       cloudify launch|run <host>                      launch <host> remote host 
       cloudify delete|del <host>                      remove delete <host> remote host (must be stopped first)
       cloudify delete|del <host> --force              force delete <host> remote host 
       cloudify shell <host>                           open a shell session on <host> remote host
       cloudify --on|on|o <host>                       <host> remote host to run action on
       cloudify --test|test|t                          helper to test code 
EOF
}


