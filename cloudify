# Backup files
pkg_backup() {
  PKG_DEBUG "Running backup"

  # Do we keep the same name for the target and its target
  same=false; [[ "${1-}" == "--same" ]] && same=true && shift

  if [[ ! -e ${1-} ]]; then
    PKG_DEBUG "File or directory ${1-} not found"
    return 1
  fi
  
  PKG_DEBUG "Testing same flag"

  # Derive a unique file name for the backup by getting the absolute path of the target and replacing by '/' by '__'

  if "$same"; then
    backup_name=$(basename ${1-}) 
  else 
    backup_name=$(dirname ${1-}) && backup_name="$(basename ${1-})${backup_name//\//@}"
  fi
  backup_name="${CLOUDIFY_TMP}"/backup/${backup_name}

  PKG_DEBUG "Backing up ${1-} to ${backup_name}"

  [[ -d "${CLOUDIFY_TMP}"/backup ]] || PKG_DEBUG "Creating ${CLOUDIFY_TMP}/backup directory" && mkdir -p "${CLOUDIFY_TMP}"/backup 

  rm -rf  "${backup_name}.bak.5"                         2>/dev/null 
  mv      "${backup_name}.bak.4" "${backup_name}.bak.5"  2>/dev/null 
  rm -rf  "${backup_name}.bak.4"                         2>/dev/null 
  mv      "${backup_name}.bak.3" "${backup_name}.bak.4"  2>/dev/null  
  rm -rf  "${backup_name}.bak.3"                         2>/dev/null
  mv      "${backup_name}.bak.2" "${backup_name}.bak.3"  2>/dev/null 
  rm -rf  "${backup_name}.bak.2"                         2>/dev/null
  mv      "${backup_name}.bak.1" "${backup_name}.bak.2"  2>/dev/null
  rm -rf  "${backup_name}.bak.1"                         2>/dev/null
  mv      "${backup_name}.bak"   "${backup_name}.bak.1"  2>/dev/null
  rm -rf  "${backup_name}.bak"                           2>/dev/null
  mv      "${backup_name}"       "${backup_name}.bak"    2>/dev/null
  rm -rf  "${backup_name}"                               2>/dev/null
  cp -paf "$1" "${backup_name}"
}

pkg_restore() {
  PKG_DEBUG "Running Restore"

  [[ ! -d "${CLOUDIFY_TMP}"/backup ]] && PKG_DEBUG "No backup directory found" && return 1 
  
  # Do we keep the same name for the target and its target
  same=false; [[ "${1-}" == "--same" ]] && same=true && shift

  # Derive a unique file name for the backup by getting the absolute path of the target and replacing by '/' by '__'
  "$same" && backup_name=${1-} || backup_name=$(dirname $1) && backup_name="$(basename ${1-})${backup_name//\//@}"
  backup_name="${CLOUDIFY_TMP}"/backup/${backup_name}

  if [[ ! -e "${backup_name-}" ]]; then
    PKG_DEBUG "File or directory ${1-} has no backup"
    return 1
  fi

  PKG_DEBUG "Restoring ${backup_name} to ${1-}"

  trash-put "$1"                                       2>/dev/null 
  mv     "${backup_name}" "$1"                         2>/dev/null 
  rm -rf "${backup_name}"                              2>/dev/null 
  mv     "${backup_name}.bak"  "${backup_name}"        2>/dev/null
  rm -rf "${backup_name}.bak"                          2>/dev/null 
  mv     "${backup_name}.bak.1" "${backup_name}.bak"   2>/dev/null
  rm -rf "${backup_name}.bak.1"                        2>/dev/null 
  mv     "${backup_name}.bak.2" "${backup_name}.bak.1" 2>/dev/null
  rm -rf "${backup_name}.bak.2"                        2>/dev/null 
  mv     "${backup_name}.bak.3" "${backup_name}.bak.2" 2>/dev/null 
  rm -rf "${backup_name}.bak.3"                        2>/dev/null 
  mv     "${backup_name}.bak.4" "${backup_name}.bak.3" 2>/dev/null 
  rm -rf "${backup_name}.bak.4"                        2>/dev/null 
  mv     "${backup_name}.bak.5" "${backup_name}.bak.4" 2>/dev/null 
  
  return 0                             # If we're then everything is ok. Roll back failures are exptected.
}


