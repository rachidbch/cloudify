}

# Parse git urls
# Description: Parse all git urls format
# Syntax: cloudify_parse_git_url <url> [[url|proto|user|pass|host|domain|subdomain|port|path|account|project]]"
# Example: cloudify_parse_git_url 'git@github.com/acme/project/repo.git/' 'host,account,project'
#          This writes requested segments on stdout with a 'segment: <segment>' on each line
# Example: cloudify_parse_git_url ssh://user@host.xz:port/path/to/repo.git/
#          This writes all segments on stdout with a 'segment: <segment>' on each line
# Code copied and tweaked from https://janikvonrotz.ch/2021/03/09/parse-url-in-shell-script/
# Supported formats are listed on this [stackoverflow question](https://stackoverflow.com/questions/31801271/what-are-the-supported-git-url-formats)
# Some results we should have
#    url                       host_port        port        Prot       host_port        port   host
#    -----------------------------------------------------------------------------------------------------
#    github.com:/toto/tata     github.com:      ''          SSH        github.com        ''     github.com
#    github.com:toto/tata      github.com:toto  toto        SSH        github.com        ''     github.com
#    github.com:80/titi        github.com:80    80          HTTPS      github.com:80     80     github.com
#    github.com/titi           github.com       ''          HTTPS      github.com        ''     github.com

function cloudify_parse_git_url() {

    # get protocol
    # if proto isn't given, we're parsing a git format  (user@host.xz:path/to/repo.git)
    [[ ! -z "${1-}" ]] || return 1
    #echo >&2 $1

    local proto="$(echo $1 | grep :// | sed -e's,^\(.*://\).*,\1,g')"
    [[ -z "${proto-}" || "${proto-}" == *:// ]] || return 1

    # remove the protocol
    local url="$(echo ${1/$proto/})"
    [[ ! -z "${url-}" ]] || return 1

    # extract the user (if any)
    local userpass="$(echo $url | grep @ | cut -d@ -f1)"
    local pass="$(echo $userpass | grep : | cut -s -d: -f2)"
    if [ -n "$pass" ]; then
        local user="$(echo $userpass | grep : | cut -d: -f1)"
    else
        user=$userpass
    fi

    # remove the user and password
    url="$(echo ${url/$userpass@/})"
    [[ ! -z "${url-}" ]] || return 1

    # extract the host and port
    local host_port
    host_port="$(echo ${url} | cut -d/ -f1)"
    [[ ! -z "${host_port-}" ]] || return 1

    port="$(echo ${host_port} | cut -s -d: -f2)"

    if [[ ${host_port-} == *:* && ! ${port-} =~ ^[0-9]+$ ]]; then
        [[ -z "${proto-}" ]] && proto="git://"
        host_port="$(echo ${url} | cut -d: -f1)"
        [[ ! -z "${host_port-}" ]] || return 1
        port=""
        host=$host_port
    else
        [[ -z "${proto-}" ]] && proto="https://"
        host="$(echo ${host_port} | cut -d: -f1)"
        [[ ! -z "${host-}" ]] || return 1
    fi

    # extract the path (if any)
    local path
    path="$(echo ${url#$host_port})"
    path="$(echo ${path#:})"

    # extract domain and subdomain

    local levels=$(echo $host | grep -o "\." | wc -l)
    if [ $levels -eq "1" ]; then
        domain=$host
    fi
    if [ $levels -eq "2" ]; then
        domain=$(echo $host | awk -F"." '{print $2 "." $3}')
        subdomain=$(echo $host | awk -F"." '{print $1}')
    fi
    [[ ! -z "${domain-}" ]] || return 1

    # extract account and project
    local account
    local project

    # TODO just remove any leading slash
    # account=$(echo $path | sed 's,^/,,' | cut -d/ -f1)
    # project=$(echo $path | sed 's,^/,,' | cut -s -d/ -f2)

    if [[ "$path" == /* ]]; then
        account=$(echo $path | cut -s -d/ -f2)
        project=$(echo $path | cut -s -d/ -f3)
    else
        account=$(echo $path | cut -d/ -f1)
        project=$(echo $path | cut -s -d/ -f2)
    fi

    if [[ -z "${2-}" ]]; then
        echo -e "url: $url\nproto: $proto\nuser: $user\npass: $pass\nhost_port: $host_port\nhost: $host\ndomain: $domain\nsubdomain: $subdomain\nport: $port\npath: $path\naccount: $account\nproject: $project"
    else
        for f in $(echo $2 | sed "s/,/ /g"); do
            # =todo= simplify this! A 'case $f in url|proto|...' should do
            case $f in
            url)
                echo $url
                ;;
            proto)
                echo $proto
                ;;
            user)
                echo $user
                ;;
            pass)
                echo $pass
                ;;
            host)
                echo $host
                ;;
            domain)
                echo $domain
                ;;
            subdomain)
                echo $subdomain
                ;;
            port)
                echo $port
                ;;
            path)
                echo $path
                ;;
            account)
                echo $account
                ;;
            project)
                echo $project
                ;;
            esac
        done
    fi

    #   Unused
    #   local port="$(echo $host_port | sed -e 's,^.*:,:,g' -e 's,.*:\([0-9]*\).*,\1,g' -e 's,[^0-9],,g')"
}

# Is an url a git url ?
# Description: Checks if an url is a git url
# under the hood, the url is parsed. If the parsing fails, we assume the input isn't an url
function cloudify_is_git_url() {
    cloudify_parse_git_url $1 &>/dev/null
}

# Get user and password of running cloudify
# usage: cloudify_get_password password                 store current user's password in 'password' variable
# usage: cloudify_get_password password user            also store current user in 'password' variable
# usage: cloudify_get_password password user host       also store current host in 'host' variable
function cloudify_get_password() {
    local pwd_var_name="$1"
    local user_var_name="$2"
    local host_var_name="$3"

    [[ -z $pwd_var_name ]] && die "cloudify_get_password function called with no argume"
    [[ $pwd_var_name == *\ * ]] && die "cloudify_get_password function called with argument containing a space"
    declare "$pwd_var_name"="$CLOUDIFY_HOSTPWD"
    [[ -z "$user_var_name" ]] || declare "$user_var_name"=$(whoami)
    [[ -z "$host_var_name" ]] || declare "$host_var_name"=$(hostname)
}

# Write entries in /etc/hosts
# Usage: add_in_hosts "IP1 hostname" "IP2 hostname2"            add these two hostnames in /etc/hosts and makes sure there's no doublon
# =todo= Make it compatible with zsh shell
function add_in_hosts() {
    $DEBUG && PKG_PAUSE "About to execute: add_in_hosts"

    #local hostpwd="${CLOUDIFY_LOCAL_PWD-$CLOUDIFY_REMOTE_PWD}"
    cloudify_get_password password user host
    [[ -z ${password} ]] && die "Password not set for user $user on host $host."

    # sed special characters have to be escaped. We're liberal here.
    local escaped_hosts_lines=()
    for host_line in "${@}"; do
        PKG_DEBUG "Adding '$host_line'"
        host_line=$(echo "$host_line" |
            sed 's/\//\\\//g' |
            sed 's/\*/\\*/g' |
            sed 's/\-/\\-/g' |
            sed 's/\!/\\!/g' |
            sed 's/\=/\\=/g' |
            sed 's/\:/\\:/g' |
            sed 's/\[/\\[/g' | sed 's/\]/\\]/g' |
            sed 's/\\(/\\(/g' | sed 's/\\)/\\)/g')

        escaped_host_lines+=("$host_line")
    done

    PKG_DEBUG_LN "ENV TO SETUP:"
    for host_line in "${escaped_host_lines[@]}"; do
        PKG_DEBUG "About to insert: '$host_line'"
    done

    # Reserve cloudify space in /etc/hosts
    PKG_DEBUG_LN "Reserve cloudify space inside /etc/hosts"
    grep -qFx "# CLOUDIFY HOSTS START" /etc/hosts || command sudo -kS -p '' sed -i -e '$a\\n# CLOUDIFY HOSTS START\n# CLOUDIFY HOSTS END' /etc/hosts <<<$password

    # Insert new hosts lines
    PKG_DEBUG_LN "Inserting host lines"
    for host_line in "${escaped_host_lines[@]}"; do
        PKG_DEBUG "Inserting: $host_line"
        #$DEBUG && PKG_PAUSE "break 4"
        # =TODO= I had to redirect sudo output to /dev/null to avoid the prompt beeing displayed. Even with "-p ''".
        #        Exact same line above didn't need that. Why that?
        command sudo -kSp '' sed -i -e "/# CLOUDIFY HOSTS END/i $host_line" /etc/hosts &>/dev/null <<<$password
        PKG_DEBUG "Inserted: $host_line"
    done
}

